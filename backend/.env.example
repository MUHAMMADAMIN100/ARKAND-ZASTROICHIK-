# Локально можно оставить пустым — используется SQLite (aiosqlite).
# На Railway переменная DATABASE_URL прокидывается автоматически из плагина PostgreSQL.
DATABASE_URL=

# Секрет для подписи JWT (в проде задать длинную случайную строку)
SECRET_KEY=arkand-dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Разрешённые источники для CORS (домен фронта на Vercel), через запятую.
# * — разрешить всё (удобно для разработки).
CORS_ORIGINS=*

# Создавать демо-данные при первом старте, если БД пустая.
SEED_ON_STARTUP=true
